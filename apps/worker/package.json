{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @shipwright/observability build && pnpm --filter @shipwright/db build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "start:dev": "tsx watch src/index.ts",
    "lint": "echo 'worker lint placeholder'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @shipwright/observability build && vitest run",
    "test:integration": "vitest run"
  },
  "dependencies": {
    "@shipwright/db": "workspace:*",
    "@shipwright/observability": "workspace:*",
    "pg": "^8.13.1"
  }
}
